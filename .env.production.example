APP_NAME="Liga Anak Piaman Laweh"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ligaanakpiamanlaweh.com
ADMIN_SEED_PASSWORD=ganti-hanya-jika-menjalankan-admin-seeder
TRUSTED_PROXIES=

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=cache
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=liga_anak_piaman_laweh
DB_USERNAME=liga_user
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_TABLE=sessions
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

QUEUE_CONNECTION=database
DB_QUEUE_TABLE=jobs
DB_QUEUE=default
DB_QUEUE_RETRY_AFTER=120
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=database
DB_CACHE_TABLE=cache
CACHE_PREFIX=liga_anak_piaman_laweh_prod

MAIL_MAILER=log
# Ubah ke smtp jika fitur email diaktifkan.
# MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ligaanakpiamanlaweh.com"
MAIL_FROM_NAME="${APP_NAME}"

ID_CARDS_COMPETITION_NAME="Liga Anak Piaman Laweh"
ID_CARDS_WEBSITE=ligaanakpiamanlaweh.com
ID_CARDS_ORGANIZER="Liga Anak Piaman Laweh Organizer"
ID_CARDS_CHROME_PATH=/usr/bin/chromium
ID_CARDS_NODE_BINARY=/usr/bin/node
ID_CARDS_NODE_MODULES_PATH=/var/www/liga-anak-piaman-laweh/storage/app/id-card-node/node_modules
ID_CARDS_TIMEOUT=90
ID_CARDS_WAIT_UNTIL=load
ID_CARDS_NO_SANDBOX=true

VITE_APP_NAME="${APP_NAME}"
