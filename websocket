Buat service token
File: app/Services/PresenceTokenService.php
<?php
namespace App\Services;
use Illuminate\Support\Str;
class PresenceTokenService
{
    public function issue(string $issuer, string $websiteId, string $visitorId, string $tabId, int $ttl = 300): string
    {
        $now = time();
        $payload = [
            'iss' => $issuer,
            'aud' => config('services.presence.audience', 'analytics-live-presence'),
            'websiteId' => $websiteId,
            'visitorId' => $visitorId,
            'tabId' => $tabId,
            'iat' => $now,
            'exp' => $now + $ttl,
            'jti' => (string) Str::uuid(),
        ];
        $encodedPayload = $this->base64UrlEncode(json_encode($payload, JSON_UNESCAPED_SLASHES));
        $signature = hash_hmac(
            'sha256',
            $encodedPayload,
            (string) config('services.presence.secret'),
            true,
        );
        return $encodedPayload . '.' . $this->base64UrlEncode($signature);
    }
    private function base64UrlEncode(string $value): string
    {
        return rtrim(strtr(base64_encode($value), '+/', '-_'), '=');
    }
}
Buat controller token
File: app/Http/Controllers/PresenceTokenController.php
<?php
namespace App\Http\Controllers;
use App\Services\PresenceTokenService;
use Illuminate\Http\JsonResponse;
use Illuminate\Http\Request;
use Illuminate\Support\Str;
class PresenceTokenController extends Controller
{
    public function __invoke(Request $request, PresenceTokenService $presenceTokenService): JsonResponse
    {
        $validated = $request->validate([
            'tabId' => ['required', 'string', 'max:100'],
        ]);
        $websiteId = (string) config('services.presence.website_id');
        abort_unless($websiteId, 500, 'Presence website ID is not configured.');
        $visitorId = (string) ($request->cookie('hanara_visitor_id') ?: Str::uuid());
        $issuer = $request->getHost();
        $token = $presenceTokenService->issue(
            issuer: $issuer,
            websiteId: $websiteId,
            visitorId: $visitorId,
            tabId: $validated['tabId'],
            ttl: 300,
        );
        return response()->json([
            'websiteId' => $websiteId,
            'visitorId' => $visitorId,
            'tabId' => $validated['tabId'],
            'token' => $token,
            'wsUrl' => config('services.presence.ws_url'),
            'heartbeatMs' => 15000,
        ])->cookie(
            'hanara_visitor_id',
            $visitorId,
            60 * 24 * 365,
            '/',
            null,
            true,
            false,
            false,
            'Lax',
        );
    }
}
