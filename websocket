<script>
(() => {
  const TOKEN_URL = @json(route('presence.token'));
  const HEARTBEAT_FALLBACK_MS = 15000;
  const TAB_KEY = 'hanara-live-tab-id';
  function getOrCreateTabId() {
    let tabId = sessionStorage.getItem(TAB_KEY);
    if (!tabId) {
      tabId = crypto.randomUUID();
      sessionStorage.setItem(TAB_KEY, tabId);
    }
    return tabId;
  }
  const tabId = getOrCreateTabId();
  let config = null;
  let ws = null;
  let heartbeatTimer = null;
  let reconnectTimer = null;
  let reconnectDelay = 1000;
  let lastPath = location.pathname + location.search + location.hash;
  async function fetchConfig() {
    const response = await fetch(TOKEN_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
        'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]')?.content || '',
      },
      credentials: 'same-origin',
      body: JSON.stringify({ tabId }),
    });
    if (!response.ok) {
      throw new Error('Failed to fetch presence token');
    }
    config = await response.json();
    return config;
  }
  function buildPayload(type) {
    return {
      type,
      websiteId: config.websiteId,
      visitorId: config.visitorId,
      tabId: config.tabId,
      token: config.token,
      path: location.pathname + location.search + location.hash,
      title: document.title || '',
      hostname: location.hostname,
      referrer: document.referrer || '',
    };
  }
  function send(type) {
    if (!ws || ws.readyState !== WebSocket.OPEN || !config) return;
    ws.send(JSON.stringify(buildPayload(type)));
  }
  function startHeartbeat() {
    stopHeartbeat();
    heartbeatTimer = setInterval(() => {
      send('presence:heartbeat');
    }, config?.heartbeatMs || HEARTBEAT_FALLBACK_MS);
  }
  function stopHeartbeat() {
    if (heartbeatTimer) {
      clearInterval(heartbeatTimer);
      heartbeatTimer = null;
    }
  }
  function scheduleReconnect() {
    if (reconnectTimer) return;
    reconnectTimer = setTimeout(async () => {
      reconnectTimer = null;
      reconnectDelay = Math.min(reconnectDelay * 2, 10000);
      try {
        await fetchConfig();
        connect();
      } catch (_) {
        scheduleReconnect();
      }
    }, reconnectDelay);
  }
  function connect() {
    ws = new WebSocket(config.wsUrl);
    ws.addEventListener('open', () => {
      reconnectDelay = 1000;
      send('presence:join');
      startHeartbeat();
    });
    ws.addEventListener('close', () => {
      stopHeartbeat();
      scheduleReconnect();
    });
    ws.addEventListener('error', () => {
      if (ws) ws.close();
    });
  }
  function handlePathChange() {
    const nextPath = location.pathname + location.search + location.hash;
    if (nextPath === lastPath) return;
    lastPath = nextPath;
    send('presence:navigate');
  }
  const originalPushState = history.pushState;
  const originalReplaceState = history.replaceState;
  history.pushState = function () {
    originalPushState.apply(this, arguments);
    handlePathChange();
  };
  history.replaceState = function () {
    originalReplaceState.apply(this, arguments);
    handlePathChange();
  };
  window.addEventListener('popstate', handlePathChange);
  window.addEventListener('hashchange', handlePathChange);
  document.addEventListener('visibilitychange', () => {
    if (document.visibilityState === 'hidden') {
      send('presence:heartbeat');
    }
  });
  window.addEventListener('beforeunload', () => {
    send('presence:leave');
  });
  window.addEventListener('pagehide', () => {
    send('presence:leave');
  });
  fetchConfig().then(connect).catch(() => {
    scheduleReconnect();
  });
})();
</script>
