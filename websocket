window.hanaraBeforeSend = function(type, payload) {
  try {
    const visitorId = document.cookie
      .split('; ')
      .find(row => row.startsWith('hanara_visitor_id='))
      ?.split('=')[1];
    if (!payload || !visitorId) return payload;
    return {
      ...payload,
      id: decodeURIComponent(visitorId),
    };
  } catch (_) {
    return payload;
  }
};
